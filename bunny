#!/usr/bin/env python3
import os
import platform
import shutil
import subprocess
import sys
from pathlib import Path

BUNNY_CLI_VERSION = "1.0.0"


def default_port() -> str:
    env_port = os.getenv("BUNNY_PORT")
    if env_port:
        return env_port

    system = platform.system().lower()
    if system == "windows":
        return _find_serial_port_windows() or "COM3"
    if system == "darwin":
        return "/dev/cu.usbserial"
    return "/dev/ttyUSB0"


def _find_serial_port_windows() -> str | None:
    """Try to find an available serial port on Windows."""
    try:
        import serial.tools.list_ports
        
        ports = serial.tools.list_ports.comports()
        for port in ports:
            # Prefer ESP32 ports
            if "ESP" in port.description or "CH340" in port.description or "CP2102" in port.description:
                return port.device
        # Return first available port
        if ports:
            return ports[0].device
    except ImportError:
        # pyserial not installed, fall back to default
        pass
    except Exception:
        # Any other error, fall back to default
        pass
    return None


def default_baud() -> str:
    return os.getenv("BUNNY_BAUD", "115200")


