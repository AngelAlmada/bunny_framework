def run_idf_cmd(extra_args: list[str]) -> int:
    """Run idf.py commands by automatically sourcing the ESP-IDF environment."""
    system = platform.system().lower()
    
    # Locate ESP-IDF directory
    idf_path_env = os.getenv("IDF_PATH")
    if idf_path_env and Path(idf_path_env).exists():
        idf_dir = Path(idf_path_env)
    else:
        idf_dir = Path.home() / "esp" / "esp-idf"
    
    if not idf_dir.exists():
        print("Error: ESP-IDF not found. Please run 'bunny install' first.", file=sys.stderr)
        return 1

    idf_py = idf_dir / "tools" / "idf.py"
    
    print(f"[bunny] Auto-loading ESP-IDF environment from {idf_dir}")
    
    try:
        if system == "windows":
            export_script = idf_dir / "export.bat"
            if not export_script.exists():
                print(f"Error: {export_script} not found.", file=sys.stderr)
                return 1
            cmd_args = " ".join(extra_args)
            full_cmd = f'"{export_script}" && python "{idf_py}" {cmd_args}'
            print(f"[bunny] Running: {full_cmd}")
            subprocess.run(full_cmd, shell=True, check=True)
        else:
            export_script = idf_dir / "export.sh"
            if not export_script.exists():
                print(f"Error: {export_script} not found.", file=sys.stderr)
                return 1
            cmd_args = " ".join(extra_args)
            full_cmd = f'source "{export_script}" && python3 "{idf_py}" {cmd_args}'
            print(f"[bunny] Running: {full_cmd}")
            subprocess.run(["bash", "-c", full_cmd], check=True)
        return 0
    except subprocess.CalledProcessError as exc:
        return exc.returncode


def check_python() -> bool:
    """Check if Python 3.8+ is installed."""
    import sys as sys_module
    version = sys_module.version_info
    if version.major >= 3 and version.minor >= 8:
        print(f"[bunny] ✓ Python {version.major}.{version.minor}.{version.micro} is installed")
        return True
    return False


def check_idf() -> bool:
    """Check if ESP-IDF is installed."""
    idf_path_env = os.getenv("IDF_PATH")
    if idf_path_env and Path(idf_path_env).exists():
        idf_dir = Path(idf_path_env)
    else:
        idf_dir = Path.home() / "esp" / "esp-idf"
        
    if idf_dir.exists() and (idf_dir / "tools" / "idf.py").exists():
        print(f"[bunny] ✓ ESP-IDF is installed at {idf_dir}")
        return True
    return False


def install_espidf() -> bool:
    """Install ESP-IDF."""
    print("[bunny] Installing ESP-IDF...")
    system = platform.system().lower()
    home = Path.home()
    idf_dir = home / "esp" / "esp-idf"
    
    if idf_dir.exists():
        print(f"[bunny] ✓ ESP-IDF already exists at {idf_dir}")
        return True
    
    print(f"[bunny] Cloning ESP-IDF to {idf_dir}...")
    
    try:
        subprocess.run([
            "git", "clone", 
            "--depth", "1",
            "-b", "release/v6.0",
            "https://github.com/espressif/esp-idf.git",
            str(idf_dir)
        ], check=True)
        
        print("[bunny] ✓ ESP-IDF cloned successfully")
        
        # Run install script
        if system == "windows":
            install_script = idf_dir / "install.bat"
            if install_script.exists():
                print("[bunny] Running ESP-IDF installer...")
                subprocess.run([str(install_script)], cwd=str(idf_dir), check=True)
        else:
            install_script = idf_dir / "install.sh"
            if install_script.exists():
                print("[bunny] Running ESP-IDF installer...")
                subprocess.run(["bash", str(install_script)], cwd=str(idf_dir), check=True)
        
        print("[bunny] ✓ ESP-IDF installed successfully")
        return True
        
    except subprocess.CalledProcessError as e:
        print(f"[bunny] ✗ Failed to install ESP-IDF: {e}", file=sys.stderr)
        return False
    except Exception as e:
        print(f"[bunny] ✗ Error installing ESP-IDF: {e}", file=sys.stderr)
        return False


def run_env_setup() -> bool:
    """Setup global environment variables."""
    print("[bunny] Setting up global environment variables...")
    system = platform.system().lower()
    
    # If running as a packaged .exe, auto-copy to permanent location
    if getattr(sys, 'frozen', False) and system == "windows":
        bunny_bin_dir = Path.home() / ".bunny" / "bin"
        bunny_bin_dir.mkdir(parents=True, exist_ok=True)
        
        target_exe = bunny_bin_dir / "bunny.exe"
        try:
            print(f"[bunny] Copying bunny.exe to {target_exe}...")
            import shutil
            shutil.copy2(sys.executable, target_exe)
        except Exception as e:
            print(f"[bunny] ✗ Failed to copy executable: {e}")
            return False
            
        # Add to PATH via Windows Registry
        try:
            import winreg
            print("[bunny] Adding ~/.bunny/bin to Windows PATH...")
            key = winreg.OpenKey(winreg.HKEY_CURRENT_USER, "Environment", 0, winreg.KEY_ALL_ACCESS)
            try:
                current_path, _ = winreg.QueryValueEx(key, "Path")
            except OSError:
                current_path = ""
            
            bin_path_str = str(bunny_bin_dir)
            if bin_path_str not in current_path:
                separator = ";" if current_path and not current_path.endswith(";") else ""
                new_path = current_path + separator + bin_path_str
                winreg.SetValueEx(key, "Path", 0, winreg.REG_EXPAND_SZ, new_path)
                print(f"[bunny] ✓ Successfully added to PATH")
                
                # Notify Windows Explorer
                import ctypes
                HWND_BROADCAST = 0xFFFF
                WM_SETTINGCHANGE = 0x001A
                SMTO_ABORTIFHUNG = 0x0002
                ctypes.windll.user32.SendMessageTimeoutW(HWND_BROADCAST, WM_SETTINGCHANGE, 0, "Environment", SMTO_ABORTIFHUNG, 5000, None)
            else:
                print("[bunny] ✓ Already in PATH")
            winreg.CloseKey(key)
        except Exception as e:
            print(f"[bunny] ✗ Failed to update PATH: {e}")
            return False
        
        print("[bunny] ✓ Environment setup completed")
        return True
    else:
        # Not frozen, skip copying
        print("[bunny] Running as script. Ensure this folder is in your PATH.")
        return True


def install_command(args: list[str]) -> int:
    """Handle the install command."""
    print("\n" + "=" * 80)
    print("Bunny Framework - Development Environment Installer")
    print("=" * 80 + "\n")
    
    skip_python = "--skip-python" in args
    skip_espidf = "--skip-espidf" in args
    skip_env = "--skip-env" in args
    
    all_success = True
    
    # Check/Install Python
    if not skip_python:
        print("[bunny] Checking Python installation...")
        if not check_python():
            print("[bunny] ✗ Python 3.8+ is required but not found")
            print("[bunny] Please install Python 3.8+ from https://www.python.org/")
            all_success = False
        print()
    
    # Check/Install ESP-IDF
    if not skip_espidf:
        print("[bunny] Checking ESP-IDF installation...")
        if not check_idf():
            print("[bunny] ESP-IDF not found, installing...")
            if not install_espidf():
                all_success = False
        print()
    
    # Setup environment
    if not skip_env:
        if not run_env_setup():
            all_success = False
        print()
    
    print("=" * 80)
    if all_success:
        print("✓ Installation completed successfully!")
        print("=" * 80)
        print("\nNext steps:")
        print("1. Restart your terminal/command prompt")
        print("2. Run 'bunny flash' to flash your ESP32")
        print()
        return 0
    else:
        print("✗ Installation completed with errors")
        print("=" * 80)
        print("\nPlease check the errors above and try again.")
        print()
        return 1


def monitor_command(args: list[str]) -> int:
    """Handle the monitor command to view ESP32 serial output."""

    port = default_port()
    baud = default_baud()

    print(f"[bunny] Connecting to {port} at {baud} baud...")
    print("[bunny] Press Ctrl+] to exit the monitor\n")

    try:
        return run_idf_cmd(["-p", port, "-b", baud, "monitor"])
    except KeyboardInterrupt:
        print("\n[bunny] Monitor closed by user")
        return 0


def generate_component(args: list[str]) -> int:
    """Generate a new command, state, sensor, or event."""
    if len(args) < 2:
        print("Usage: bunny generate <type> <name>")
        print("Types: command, state, sensor, event")
        return 1

    comp_type = args[0].lower()
    name = args[1].lower()

    if comp_type not in {"command", "state", "sensor", "event"}:
        print(f"Error: Unknown component type '{comp_type}'")
        return 1

    main_dir = Path("main")
    if not main_dir.exists():
        print("Error: 'main' directory not found. Are you at the root of the project?")
        return 1

    target_dir = main_dir / f"{comp_type}s"
    target_dir.mkdir(parents=True, exist_ok=True)

    header_file = target_dir / f"{name}_{comp_type}.h"
    cpp_file = target_dir / f"{name}_{comp_type}.cpp"

    func_name = f"register_{name}_{comp_type}"

    if comp_type == "command":
        code_body = f"""    Bunny.command("{name}")
         .description("Auto-generated {name} command")
         .execute([](const bunny::Params& p) {{
             // TODO: Implement {name} logic
         }});"""
    elif comp_type == "state":
        code_body = f"""    Bunny.state("{name}", STRING)
         .description("Auto-generated {name} state")
         .build(
             []() -> const char* {{ return "UNKNOWN"; }},
             [](const char* v)   {{ /* TODO: handle setter */ }}
         );"""
    elif comp_type == "sensor":
        code_body = f"""    Bunny.sensor("{name}")
         .description("Auto-generated {name} sensor")
         .returns(NUMBER)
         .build([]() -> double {{
             // TODO: Return actual sensor reading
             return 0.0;
         }});"""
    elif comp_type == "event":
        code_body = f"""    Bunny.event("{name}")
         .description("Auto-generated {name} event")
         .build([]() {{
             // TODO: Optional hardware hook when event fires
         }});"""

    h_content = f"""#pragma once

#ifdef __cplusplus
extern "C" {{
#endif

/**
 * {name.capitalize()} {comp_type.capitalize()}
 */
void {func_name}();

#ifdef __cplusplus
}}
#endif
"""

    cpp_content = f"""#include "{name}_{comp_type}.h"
#include "bunny_sdk.h"

void {func_name}() {{
{code_body}
}}
"""
    if header_file.exists() or cpp_file.exists():
        print(f"Error: Files for {name}_{comp_type} already exist!")
        return 1

    header_file.write_text(h_content, encoding="utf-8")
    cpp_file.write_text(cpp_content, encoding="utf-8")

    print(f"[bunny] Created {header_file}")
    print(f"[bunny] Created {cpp_file}")

    # Update CMakeLists.txt
    cmake_file = main_dir / "CMakeLists.txt"
    if cmake_file.exists():
        cmake_content = cmake_file.read_text(encoding="utf-8")
        src_line = f'"{comp_type}s/{name}_{comp_type}.cpp"'
        if src_line not in cmake_content:
            cmake_content = cmake_content.replace("SRCS", f"SRCS\n        {src_line}")
            cmake_file.write_text(cmake_content, encoding="utf-8")
            print(f"[bunny] Updated {cmake_file}")

    # Update bunny_framework.cpp
    fw_file = main_dir / "bunny_framework.cpp"
    if fw_file.exists():
        fw_content = fw_file.read_text(encoding="utf-8")
        inc_line = f'#include "{comp_type}s/{name}_{comp_type}.h"'
        reg_line = f'    {func_name}();'
        
        updated = False
        if inc_line not in fw_content:
            fw_content = fw_content.replace('#include "bunny.h"', f'#include "bunny.h"\n{inc_line}')
            updated = True
        
        if reg_line not in fw_content:
            marker = "/* Register all capabilities"
            idx = fw_content.find(marker)
            if idx != -1:
                end_idx = fw_content.find("*/", idx) + 2
                if end_idx > 1:
                    fw_content = fw_content[:end_idx] + f"\n{reg_line}" + fw_content[end_idx:]
                    updated = True
        
        if updated:
            fw_file.write_text(fw_content, encoding="utf-8")
            print(f"[bunny] Updated {fw_file}")

    print(f"\\n[bunny] Successfully generated {comp_type} '{name}'")
    return 0


def destroy_component(args: list[str]) -> int:
    """Destroy a previously generated command, state, sensor, or event."""
    if len(args) < 2:
        print("Usage: bunny destroy <type> <name>")
        print("Types: command, state, sensor, event")
        return 1

    comp_type = args[0].lower()
    name = args[1].lower()

    if comp_type not in {"command", "state", "sensor", "event"}:
        print(f"Error: Unknown component type '{comp_type}'")
        return 1

    main_dir = Path("main")
    if not main_dir.exists():
        print("Error: 'main' directory not found. Are you at the root of the project?")
        return 1

    target_dir = main_dir / f"{comp_type}s"
    header_file = target_dir / f"{name}_{comp_type}.h"
    cpp_file = target_dir / f"{name}_{comp_type}.cpp"

    func_name = f"register_{name}_{comp_type}"

    deleted_files = False
    if header_file.exists():
        header_file.unlink()
        print(f"[bunny] Deleted {header_file}")
        deleted_files = True
    if cpp_file.exists():
        cpp_file.unlink()
        print(f"[bunny] Deleted {cpp_file}")
        deleted_files = True

    if not deleted_files:
        print(f"[bunny] Files for {name}_{comp_type} not found.")

    # Update CMakeLists.txt
    cmake_file = main_dir / "CMakeLists.txt"
    if cmake_file.exists():
        cmake_content = cmake_file.read_text(encoding="utf-8")
        import re
        pattern = rf'[ \t]*"{comp_type}s/{name}_{comp_type}\.cpp"\r?\n?'
        new_cmake, count = re.subn(pattern, '', cmake_content)
        if count > 0:
            cmake_file.write_text(new_cmake, encoding="utf-8")
            print(f"[bunny] Removed from {cmake_file}")

    # Update bunny_framework.cpp
    fw_file = main_dir / "bunny_framework.cpp"
    if fw_file.exists():
        fw_content = fw_file.read_text(encoding="utf-8")
        inc_pattern = rf'[ \t]*#include "{comp_type}s/{name}_{comp_type}\.h"\r?\n?'
        reg_pattern = rf'[ \t]*{func_name}\(\);\r?\n?'
        
        new_fw, count_inc = re.subn(inc_pattern, '', fw_content)
        new_fw, count_reg = re.subn(reg_pattern, '', new_fw)
        
        if count_inc > 0 or count_reg > 0:
            fw_file.write_text(new_fw, encoding="utf-8")
            print(f"[bunny] Removed from {fw_file}")

    print(f"\n[bunny] Successfully destroyed {comp_type} '{name}'")
    return 0


def create_project(args: list[str]) -> int:
    """Create a new Bunny Framework project."""
    if len(args) < 1:
        print("Usage: bunny create <project_name>")
        return 1

    project_name = args[0]
    target_dir = Path(project_name)

    if target_dir.exists():
        print(f"Error: Directory '{project_name}' already exists.")
        return 1

    print(f"\n[bunny] Creating new project: {project_name}")
    print("[bunny] Downloading Bunny Framework template...")

    try:
        # Clone the repository
        subprocess.run([
            "git", "clone",
            "https://github.com/AngelAlmada/bunny_framework.git",
            str(target_dir)
        ], check=True)
    except subprocess.CalledProcessError:
        print("\n[bunny] ✗ Failed to download framework template.")
        return 1

    print("[bunny] ✓ Download complete. Configuring project...")

    # Remove the .git directory to detach from original history
    git_dir = target_dir / ".git"
    if git_dir.exists():
        import shutil
        def on_rm_error(func, path, exc_info):
            import stat
            os.chmod(path, stat.S_IWRITE)
            os.unlink(path)
        shutil.rmtree(git_dir, onerror=on_rm_error)

    # Rename the project in CMakeLists.txt
    cmake_file = target_dir / "CMakeLists.txt"
    if cmake_file.exists():
        content = cmake_file.read_text(encoding="utf-8")
        content = content.replace("project(bunny_framework)", f"project({project_name})")
        cmake_file.write_text(content, encoding="utf-8")

    print("\n" + "=" * 80)
    print(f"✓ Project '{project_name}' created successfully!")
    print("=" * 80)
    print("\nNext steps:")
    print(f"  cd {project_name}")
    print("  bunny install")
    print("  bunny flash")
    print("\nHappy Coding!")
    return 0


def interactive_mode() -> int:
    import os
    os.system('cls' if os.name == 'nt' else 'clear')
    print(r"""
      \\
       \\_
        ( _\\
        / \\__
       / _/`"`
      {\  )_
       `""" + '"""' + r"""`\
    BUNNY FRAMEWORK INSTALLER
    """)
    print("Welcome to the Bunny Framework setup!")
    print("---------------------------------------")
    print(" [1] Install global dependencies (ESP-IDF)")
    print(" [2] Show Command Line Help")
    print(" [3] Exit")
    print("---------------------------------------")
    
    try:
        choice = input("\nSelect an option [1-3]: ").strip()
        if choice == "1":
            install_command([])
        elif choice == "2":
            usage()
        elif choice == "3":
            print("\nGoodbye!")
            return 0
        else:
            print("\nInvalid option.")
    except (KeyboardInterrupt, EOFError):
        pass

    input("\nPress Enter to exit...")
    return 0


def main() -> int:
    import io
    if hasattr(sys.stdout, 'buffer'):
        sys.stdout = io.TextIOWrapper(sys.stdout.buffer, encoding='utf-8', errors='replace')
    if hasattr(sys.stderr, 'buffer'):
        sys.stderr = io.TextIOWrapper(sys.stderr.buffer, encoding='utf-8', errors='replace')

    args = sys.argv[1:]
    
    # INTERACTIVE MODE ON DOUBLE CLICK
    if not args:
        return interactive_mode()

    if args[0] in {"-h", "--help", "help"}:
        usage()
        return 0

    if args[0] in {"-v", "--version", "version"}:
        print(f"Bunny Framework CLI v{BUNNY_CLI_VERSION}")
        return 0

    if args[0] in {"install", "i"}:
        return install_command(args[1:])

    if args[0] in {"monitor", "m"}:
        return monitor_command(args[1:])

    if args[0] in {"generate", "g"}:
        return generate_component(args[1:])

    if args[0] in {"destroy", "rm", "d"}:
        return destroy_component(args[1:])

    if args[0] in {"create", "c"}:
        return create_project(args[1:])

    if args[0] != "flash":
        usage()
        return 1

    port = default_port()
    baud = default_baud()

    try:
        if len(args) == 1:
            return run_idf_cmd(["-p", port, "-b", baud, "flash"])

        if len(args) == 2 and args[1] == "clean":
            # Try fullclean first, but if it fails due to managed_components issues, use manual cleanup
            try:
                run_idf_cmd(["fullclean"])
            except subprocess.CalledProcessError:
                # If fullclean fails, manually remove build directory and reconfigure
                print("[bunny] fullclean failed, cleaning manually...")
                build_dir = Path("build")
                if build_dir.exists():
                    shutil.rmtree(build_dir)
                    print("[bunny] Removed build directory")
            
            run_idf_cmd(["reconfigure"])
            return run_idf_cmd(["-p", port, "-b", baud, "flash"])

        usage()
        return 1
    except subprocess.CalledProcessError as exc:
        return exc.returncode


if __name__ == "__main__":
    raise SystemExit(main())
